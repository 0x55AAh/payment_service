# API Settings
API_KEY=test_api_key

# Database Settings
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/payment_service

# Message Broker Settings
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_JSON=False

# Docker Compose (Optional helper variables)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=payment_service
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
